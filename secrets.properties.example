# =========================================================
# API KEYS (NO subir el archivo real al repositorio)
# =========================================================
# Copiar este archivo y renombrarlo a:
# secrets.properties
#
# Luego completar los valores reales.
#
# Este archivo es usado por el plugin:
# com.google.android.mapsplatform.secrets-gradle-plugin
# =========================================================

# Google Maps API Key (requerido)
# Obtener desde Google Cloud Console
MAPS_API_KEY=

# Puedes agregar más claves si necesitas
# EJEMPLO:
# OTHER_API_KEY=