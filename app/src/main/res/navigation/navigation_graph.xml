<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/navigation_graph"
    app:startDestination="@id/FBase">

    <fragment
        android:id="@+id/FBase"
        android:name="com.upd.kvupd.ui.fragment.base.FBase"
        android:label="@string/app_name"
        tools:layout="@layout/fragment_f_base">

        <action
            android:id="@+id/action_FBase_to_BDConfiguracion"
            app:destination="@id/BDConfiguracion"
            app:enterAnim="@anim/slide_in_right"
            app:exitAnim="@anim/slide_out_left"
            app:popEnterAnim="@anim/slide_in_left"
            app:popExitAnim="@anim/slide_out_right" />

        <action
            android:id="@+id/action_FBase_to_DSincronizarDiario"
            app:destination="@id/DSincronizarDiario"
            app:enterAnim="@anim/slide_in_right"
            app:exitAnim="@anim/slide_out_left"
            app:popEnterAnim="@anim/slide_in_left"
            app:popExitAnim="@anim/slide_out_right" />

        <action
            android:id="@+id/action_FBase_to_FRastreo"
            app:destination="@id/FRastreo"
            app:enterAnim="@anim/slide_in_right"
            app:exitAnim="@anim/slide_out_left"
            app:popEnterAnim="@anim/slide_in_left"
            app:popExitAnim="@anim/slide_out_right" />

        <action
            android:id="@+id/action_FBase_to_FCartera"
            app:destination="@id/FCartera"
            app:enterAnim="@anim/slide_in_right"
            app:exitAnim="@anim/slide_out_left"
            app:popEnterAnim="@anim/slide_in_left"
            app:popExitAnim="@anim/slide_out_right" />

        <action
            android:id="@+id/action_FBase_to_FBaja"
            app:destination="@id/FBaja"
            app:enterAnim="@anim/slide_in_right"
            app:exitAnim="@anim/slide_out_left"
            app:popEnterAnim="@anim/slide_in_left"
            app:popExitAnim="@anim/slide_out_right" />

        <action
            android:id="@+id/action_FBase_to_FAlta"
            app:destination="@id/FAlta"
            app:enterAnim="@anim/slide_in_right"
            app:exitAnim="@anim/slide_out_left"
            app:popEnterAnim="@anim/slide_in_left"
            app:popExitAnim="@anim/slide_out_right" />

        <action
            android:id="@+id/action_FBase_to_FEncuesta"
            app:destination="@id/FEncuesta"
            app:enterAnim="@anim/slide_in_right"
            app:exitAnim="@anim/slide_out_left"
            app:popEnterAnim="@anim/slide_in_left"
            app:popExitAnim="@anim/slide_out_right" />

        <action
            android:id="@+id/action_FBase_to_FReporte"
            app:destination="@id/FReporte"
            app:enterAnim="@anim/slide_in_right"
            app:exitAnim="@anim/slide_out_left"
            app:popEnterAnim="@anim/slide_in_left"
            app:popExitAnim="@anim/slide_out_right" />

        <action
            android:id="@+id/action_FBase_to_FServidor"
            app:destination="@id/FServidor"
            app:enterAnim="@anim/slide_in_right"
            app:exitAnim="@anim/slide_out_left"
            app:popEnterAnim="@anim/slide_in_left"
            app:popExitAnim="@anim/slide_out_right" />

    </fragment>

    <dialog
        android:id="@+id/BDConfiguracion"
        android:name="com.upd.kvupd.ui.dialog.BDConfiguracion"
        android:label="Configuracion"
        tools:layout="@layout/bottom_configuracion" />

    <dialog
        android:id="@+id/DSincronizarDiario"
        android:name="com.upd.kvupd.ui.dialog.DSincronizarDiario"
        android:label="Sincronizacion"
        tools:layout="@layout/custom_dialog_progressbar" />

    <fragment
        android:id="@+id/FRastreo"
        android:name="com.upd.kvupd.ui.fragment.FRastreo"
        android:label="Pedimap"
        tools:layout="@layout/fragment_f_rastreo" />

    <fragment
        android:id="@+id/FCartera"
        android:name="com.upd.kvupd.ui.fragment.cartera.FCartera"
        android:label="Cartera"
        tools:layout="@layout/fragment_f_cartera">

        <action
            android:id="@+id/action_FCartera_to_BDBajaCliente"
            app:destination="@id/BDBajaCliente"
            app:enterAnim="@anim/slide_in_right"
            app:exitAnim="@anim/slide_out_left"
            app:popEnterAnim="@anim/slide_in_left"
            app:popExitAnim="@anim/slide_out_right" />

    </fragment>

    <fragment
        android:id="@+id/FBaja"
        android:name="com.upd.kvupd.ui.fragment.baja.FBaja"
        android:label="Bajas"
        tools:layout="@layout/fragment_f_baja">

        <action
            android:id="@+id/action_FBaja_to_BDDetalleBaja"
            app:destination="@id/BDDetalleBaja"
            app:enterAnim="@anim/slide_in_right"
            app:exitAnim="@anim/slide_out_left"
            app:popEnterAnim="@anim/slide_in_left"
            app:popExitAnim="@anim/slide_out_right" />

    </fragment>

    <dialog
        android:id="@+id/BDBajaCliente"
        android:name="com.upd.kvupd.ui.dialog.BDBajaCliente"
        android:label="Baja cliente"
        tools:layout="@layout/bottom_bajacliente">

        <argument
            android:name="cliente"
            app:argType="com.upd.kvupd.data.model.FlowCliente" />

    </dialog>

    <dialog
        android:id="@+id/BDDetalleBaja"
        android:name="com.upd.kvupd.ui.dialog.BDDetalleBaja"
        android:label="Detalle Baja cliente"
        tools:layout="@layout/bottom_detallebaja">

        <argument
            android:name="detalle"
            app:argType="com.upd.kvupd.data.model.FlowBajaSupervisor" />

    </dialog>

    <fragment
        android:id="@+id/FAlta"
        android:name="com.upd.kvupd.ui.fragment.altas.FAlta"
        android:label="Alta clientes"
        tools:layout="@layout/fragment_f_alta">

        <action
            android:id="@+id/action_FAlta_to_FAltaDatos"
            app:destination="@id/FAltaDatos"
            app:enterAnim="@anim/slide_in_right"
            app:exitAnim="@anim/slide_out_left"
            app:popEnterAnim="@anim/slide_in_left"
            app:popExitAnim="@anim/slide_out_right" />

    </fragment>

    <fragment
        android:id="@+id/FAltaDatos"
        android:name="com.upd.kvupd.ui.fragment.altas.FAltaDatos"
        android:label="Completando datos alta"
        tools:layout="@layout/fragment_f_altadatos">

        <argument
            android:name="empleado"
            app:argType="string" />

        <argument
            android:name="idaux"
            app:argType="string" />

        <argument
            android:name="fecha"
            app:argType="string" />

        <argument
            android:name="longitud"
            app:argType="float" />

        <argument
            android:name="latitud"
            app:argType="float" />

    </fragment>

    <fragment
        android:id="@+id/FEncuesta"
        android:name="com.upd.kvupd.ui.fragment.encuesta.FEncuesta"
        android:label="Encuesta"
        tools:layout="@layout/fragment_f_encuesta" />

    <fragment
        android:id="@+id/FReporte"
        android:name="com.upd.kvupd.ui.fragment.reportes.FReporte"
        android:label="Reporte ventas"
        tools:layout="@layout/fragment_f_reporte">

        <action
            android:id="@+id/action_FReporte_to_FDetalle"
            app:destination="@id/FDetalle"
            app:enterAnim="@anim/slide_in_right"
            app:exitAnim="@anim/slide_out_left"
            app:popEnterAnim="@anim/slide_in_left"
            app:popExitAnim="@anim/slide_out_right" />

    </fragment>

    <fragment
        android:id="@+id/FDetalle"
        android:name="com.upd.kvupd.ui.fragment.reportes.FDetalle"
        android:label="Detalle del reporte"
        tools:layout="@layout/fragment_f_detalle">

        <argument
            android:name="params"
            app:argType="com.upd.kvupd.ui.fragment.reportes.modelUI.DetalleParams" />

    </fragment>

    <fragment
        android:id="@+id/FServidor"
        android:name="com.upd.kvupd.ui.fragment.servidor.FServidor"
        android:label="Servidor"
        tools:layout="@layout/fragment_f_servidor" />

</navigation>