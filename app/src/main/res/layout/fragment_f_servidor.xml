<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="@dimen/separation_10"
    tools:context=".ui.fragment.servidor.FServidor">

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/card1"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="@dimen/separation_10"
        app:cardCornerRadius="5dp"
        app:cardElevation="3dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="horizontal"
            android:padding="@dimen/separation_10">

            <TextView
                android:id="@+id/txt_estado"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1.5"
                android:textColor="@color/purple_500"
                android:textStyle="bold"
                tools:text="Mensaje inicial de consulta al API" />

            <ImageView
                android:id="@+id/img_estado"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="0.5"
                app:srcCompat="@drawable/nube" />

        </LinearLayout>

    </com.google.android.material.card.MaterialCardView>

    <LinearLayout
        android:id="@+id/linear1"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/separation_10"
        android:orientation="horizontal"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/card1">

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_lanzar"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_margin="@dimen/separation_10"
            android:layout_weight="1"
            app:cardCornerRadius="5dp"
            app:cardElevation="3dp">

            <TextView
                android:id="@+id/txt_lanzar"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="@dimen/separation_5"
                android:gravity="center"
                android:text="Lanzar servidor nuevamente"
                app:drawableStartCompat="@drawable/servidor_basedatos"
                app:drawableTint="@color/dodgerblue" />

        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_errores"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_margin="@dimen/separation_10"
            android:layout_weight="1"
            app:cardCornerRadius="5dp"
            app:cardElevation="3dp">

            <TextView
                android:id="@+id/txt_errores"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="@dimen/separation_5"
                android:gravity="center"
                android:text="Errores durante el envio"
                app:drawableEndCompat="@drawable/servidor_fallo" />

        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rcv_servidor"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="@dimen/separation_5"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/linear1" />

</androidx.constraintlayout.widget.ConstraintLayout>