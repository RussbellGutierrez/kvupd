<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:cardCornerRadius="10dp"
    app:cardElevation="3dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:id="@+id/txt_servidor"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:paddingHorizontal="@dimen/separation_10"
            android:paddingVertical="@dimen/separation_5"
            app:drawableTopCompat="@drawable/enviar_servidor"
            tools:text="Informacion para servidor" />

        <com.google.android.material.divider.MaterialDivider
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginVertical="@dimen/separation_5" />

        <TextView
            android:id="@+id/txt_cantidad"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/separation_5"
            android:gravity="center"
            android:paddingHorizontal="@dimen/separation_10"
            android:textSize="12sp"
            android:textStyle="bold"
            tools:text="999 registros" />

        <com.google.android.material.progressindicator.LinearProgressIndicator
            android:id="@+id/pb_linear"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:indeterminate="true"
            app:indicatorColor="@color/secondaryColor"
            app:indicatorDirectionLinear="startToEnd"
            app:trackColor="@color/lightgray"
            app:trackThickness="5dp" />

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>