# =========================================================
# FIRMA DE APK (NO subir el archivo real al repositorio)
# =========================================================
# Copiar este archivo y renombrarlo a:
# keystore.properties
#
# Luego completar los valores reales de tu keystore (.jks)
# Los valores NO DEBEN LLEVAR COMILLAS
# =========================================================

# Ruta del archivo .jks (usar / o \\)
storeFile=

# Password del keystore
storePassword=

# Alias de la key
keyAlias=

# Password del alias (puede ser igual al storePassword)
keyPassword=